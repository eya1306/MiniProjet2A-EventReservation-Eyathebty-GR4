{% extends 'admin/base_admin.html.twig' %}

{% block title %}{{ event ? 'Modifier' : 'Créer' }} un événement · Admin{% endblock %}
{% block page_title %}{{ event ? 'Modifier l\'événement' : 'Créer un événement' }}{% endblock %}

{% block content %}
<div class="admin-form-card">
    {% if error %}
        <div class="alert alert-error">{{ error }}</div>
    {% endif %}

    <form method="post" action="{{ action }}" enctype="multipart/form-data" class="admin-form">
        <div class="form-grid">
            <div class="form-group">
                <label for="title">Titre de l'événement <span class="required">*</span></label>
                <input type="text" id="title" name="title" required class="form-input"
                       placeholder="ex: Concert Jazz Festival" value="{{ event ? event.title : '' }}">
            </div>

            <div class="form-group">
                <label for="location">Lieu <span class="required">*</span></label>
                <input type="text" id="location" name="location" required class="form-input"
                       placeholder="ex: Salle des fêtes, Sousse" value="{{ event ? event.location : '' }}">
            </div>

            <div class="form-group">
                <label for="date">Date et heure <span class="required">*</span></label>
                <input type="datetime-local" id="date" name="date" required class="form-input"
                       value="{{ event ? event.date | date('Y-m-d\\TH:i') : '' }}">
            </div>

            <div class="form-group">
                <label for="seats">Nombre de places <span class="required">*</span></label>
                <input type="number" id="seats" name="seats" required class="form-input"
                       min="1" placeholder="ex: 200" value="{{ event ? event.seats : '' }}">
            </div>
        </div>

        <div class="form-group">
            <label for="description">Description <span class="required">*</span></label>
            <textarea id="description" name="description" required class="form-input form-textarea"
                      rows="6" placeholder="Décrivez l'événement en détail...">{{ event ? event.description : '' }}</textarea>
        </div>

        <div class="form-group">
            <label for="image">Image de couverture</label>
            {% if event and event.image %}
                <div class="current-image">
                    <img src="{{ asset('uploads/events/' ~ event.image) }}" alt="Image actuelle" class="preview-img">
                    <p class="hint">Téléchargez une nouvelle image pour remplacer celle-ci.</p>
                </div>
            {% endif %}
            <input type="file" id="image" name="image" class="form-input" accept="image/*">
        </div>

        <div class="form-actions">
            <a href="{{ path('admin_dashboard') }}" class="btn btn-outline">Annuler</a>
            <button type="submit" class="btn btn-primary">
                {{ event ? '💾 Mettre à jour' : '✅ Créer l\'événement' }}
            </button>
        </div>
    </form>
</div>
{% endblock %}
