{% extends 'base.html.twig' %}

{% block title %}Mes Réservations · EventReserve{% endblock %}

{% block body %}
<div class="my-reservations-page">
    <h1>🎟️ Mes Réservations</h1>

    {% if reservations is empty %}
        <div class="empty-state">
            <span class="empty-icon">📭</span>
            <h2>Aucune réservation</h2>
            <p>Vous n'avez pas encore réservé d'événement.</p>
            <a href="{{ path('app_events_index') }}" class="btn btn-primary">Voir les événements</a>
        </div>
    {% else %}
        <div class="reservations-list">
            {% for reservation in reservations %}
                <div class="reservation-card">
                    <div class="reservation-info">
                        <h3>{{ reservation.event.title }}</h3>
                        <div class="reservation-meta">
                            <span>📅 {{ reservation.event.date | date('d/m/Y à H:i') }}</span>
                            <span>📍 {{ reservation.event.location }}</span>
                            <span>👤 {{ reservation.name }}</span>
                            <span>📧 {{ reservation.email }}</span>
                        </div>
                        <div class="reservation-date">
                            Réservé le {{ reservation.createdAt | date('d/m/Y H:i') }}
                        </div>
                    </div>
                    <div class="reservation-actions">
                        <a href="{{ path('app_events_show', {id: reservation.event.id}) }}"
                           class="btn-view-event">
                            Voir l'événement
                        </a>
                        <form method="post" action="{{ path('app_reservation_cancel', {id: reservation.id}) }}"
                              onsubmit="return confirm('Annuler cette réservation ?')">
                            <input type="hidden" name="_token" value="{{ csrf_token('cancel_reservation_' ~ reservation.id) }}">
                            <button type="submit" class="btn-cancel-reservation">
                                ❌ Annuler
                            </button>
                        </form>
                    </div>
                </div>
            {% endfor %}
        </div>
    {% endif %}
</div>
{% endblock %}
