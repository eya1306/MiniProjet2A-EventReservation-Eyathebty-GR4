APP_ENV=dev
APP_SECRET=change_me_to_a_random_32char_string_in_production

# Database — Docker internal network uses 'db' host
DATABASE_URL="postgresql://app_user:app_password@db:5432/event_reservation?serverVersion=15&charset=utf8"

### JWT Configuration ###
JWT_SECRET_KEY=%kernel.project_dir%/config/jwt/private.pem
JWT_PUBLIC_KEY=%kernel.project_dir%/config/jwt/public.pem
JWT_PASSPHRASE=mypassphrase
JWT_TOKEN_TTL=3600

### WebAuthn / Passkeys Configuration ###
APP_DOMAIN=localhost
WEBAUTHN_RP_NAME="Event Reservation App"

### Mailtrap SMTP (replace with your credentials from mailtrap.io) ###
MAILER_DSN=smtp://65705e58d2591d:0a5c787f879690@sandbox.smtp.mailtrap.io:2525

###> symfony/framework-bundle ###
APP_SHARE_DIR=var/share
###< symfony/framework-bundle ###

###> symfony/routing ###
# Configure how to generate URLs in non-HTTP contexts, such as CLI commands.
# See https://symfony.com/doc/current/routing.html#generating-urls-in-commands
DEFAULT_URI=http://localhost
###< symfony/routing ###

###> nelmio/cors-bundle ###
CORS_ALLOW_ORIGIN='^https?://(localhost|127\.0\.0\.1)(:[0-9]+)?$'
###< nelmio/cors-bundle ###

###> symfony/messenger ###
# Choose one of the transports below
# MESSENGER_TRANSPORT_DSN=amqp://guest:guest@localhost:5672/%2f/messages
# MESSENGER_TRANSPORT_DSN=redis://localhost:6379/messages
MESSENGER_TRANSPORT_DSN=doctrine://default?auto_setup=0
###< symfony/messenger ###






